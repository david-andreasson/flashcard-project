# Copy this file to .env and fill in your values for local development.
# .env is git-ignored and must never be committed.

# PostgreSQL (used by docker-compose.yml)
POSTGRES_USER=flashcard
POSTGRES_PASSWORD=flashcard

# Spring Boot datasource (override if you change the values above)
DATASOURCE_URL=jdbc:postgresql://localhost:5433/flashcards
DATASOURCE_USERNAME=flashcard
DATASOURCE_PASSWORD=flashcard

# Auth (change 02)
# The user who registers with this email becomes ADMIN.
APP_ADMIN_EMAIL=davidandreasson@live.com
# JWT signing secret — generate a long random value for real use (min 32 bytes).
# e.g. `openssl rand -base64 48`
APP_JWT_SECRET=dev-only-insecure-secret-change-me-0123456789abcdef
APP_JWT_ACCESS_TTL=PT15M
APP_JWT_REFRESH_TTL=P7D
# Set to true in production so auth cookies are only sent over HTTPS.
APP_COOKIE_SECURE=false
