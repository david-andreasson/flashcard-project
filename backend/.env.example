# Local secrets for running the real 1min.ai provider.
# Copy this file to backend/.env (gitignored) and fill in your key. Spring Boot loads
# backend/.env automatically via spring.config.import in application.yml — then you can
# start the app with just `./mvnw spring-boot:run` (no inline env vars).
#
# Leave this unset (or run without backend/.env) to use the default free mock provider.

AI_PROVIDER=1min
ONEMIN_API_KEY=sk-your-1min-ai-key-here

# Optional — override the model. Default is Claude Haiku 4.5; any 1min.ai model slug works
# (e.g. claude-sonnet-4-6, claude-opus-4-6, gpt-... — see 1min.ai's model list):
# ONEMIN_MODEL=claude-haiku-4-5-20251001
